# Application
ENVIRONMENT=development
DEBUG=true
APP_NAME=Vehicle Analytics Backend

# Database
DATABASE_URL=postgresql://admin:ChangeMe123!@localhost:5432/pythonapp

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=vehicle-data

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/pythonbackend-queue
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789/pythonbackend-dlq

# Workers
WORKER_INTERVAL=3600
WORKER_BATCH_SIZE=100
FIPE_API_ENABLED=true
WEB_SCRAPING_ENABLED=true
FIPE_API_BASE_URL=https://parallelum.com.br/fipe/api/v1

# Logging
LOG_LEVEL=INFO
